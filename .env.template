# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# MCP Server Configuration
# ============================================

# Server mode: "local" for development, "remote" for production
MCP_SERVER_MODE=local

# Local server command (for development)
# Use the WSL virtual environment interpreter.
MCP_SERVER_COMMAND=venv/bin/python mcp-server/server.py

# Remote server URL (for production - Railway deployment)
# Get this URL after deploying to Railway
# Example: https://optioncalculator-production.up.railway.app
MCP_SERVER_URL=

# Optional shared token for the remote MCP server.
# Set this in both the client environment and the server host/Railway variables.
MCP_SERVER_AUTH_TOKEN=

# ============================================
# Application Settings
# ============================================

# Default risk-free rate (as decimal, e.g., 0.05 for 5%)
DEFAULT_RISK_FREE_RATE=0.05

# Default volatility (as decimal, e.g., 0.30 for 30%)
DEFAULT_VOLATILITY=0.30

# ============================================
# Railway Deployment (Optional)
# ============================================

# Railway project ID (if using Railway CLI)
RAILWAY_PROJECT_ID=

# Railway environment (production, staging, etc.)
RAILWAY_ENVIRONMENT=production

# ============================================
# API Keys (Future Extensions)
# ============================================

# If you switch to paid data providers in the future:
# ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY=
# IEX_CLOUD_API_KEY=

# ============================================
# Development Settings
# ============================================

# Enable debug logging
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache duration for stock data (in seconds)
CACHE_DURATION=300

# ============================================
# Testing
# ============================================

# Use mock data for testing (avoid hitting real APIs)
USE_MOCK_DATA=false

# Test ticker symbol
TEST_TICKER=AAPL
