#:kivy 2.3.0
#:import Factory kivy.factory.Factory

<CalculatorScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        ScrollView:
            do_scroll_x: False
            
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(5)
                spacing: dp(15)
                
                # Header
                Label:
                    text: 'Option Calculator'
                    font_size: sp(24)
                    bold: True
                    size_hint_y: None
                    height: dp(40)
                    color: 0.2, 0.6, 0.86, 1
                
                # Ticker Input Section
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(5)
                    
                    Label:
                        text: 'Ticker Symbol'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(48)
                        spacing: dp(5)
                        
                        TextInput:
                            id: ticker_input
                            text: root.ticker_text
                            hint_text: 'Enter ticker (e.g., AAPL)'
                            multiline: False
                            font_size: sp(16)
                            on_text: root.on_ticker_input(self.text)
                            on_text_validate: root.load_stock_data()
                        
                        Button:
                            text: 'Load'
                            size_hint_x: 0.3
                            on_press: root.load_stock_data()
                            background_color: 0.2, 0.6, 0.86, 1
                
                # Suggestions dropdown
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(200) if root.show_suggestions else 0
                    opacity: 1 if root.show_suggestions else 0
                    
                    ScrollView:
                        size_hint_y: None
                        height: dp(200) if root.show_suggestions else 0
                        
                        GridLayout:
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)
                            
                            # Dynamic suggestion buttons
                            BoxLayout:
                                orientation: 'vertical'
                                size_hint_y: None
                                height: self.minimum_height
                                
                                # This will be populated dynamically
                
                # Company Info
                Label:
                    text: root.company_name
                    font_size: sp(16)
                    size_hint_y: None
                    height: dp(30)
                    color: 0.3, 0.3, 0.3, 1
                    halign: 'center'
                
                # Loading indicator
                Label:
                    text: 'Loading...' if root.is_loading else ''
                    font_size: sp(14)
                    size_hint_y: None
                    height: dp(20) if root.is_loading else 0
                    color: 0.5, 0.5, 0.5, 1
                
                # Separator
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: 0.7, 0.7, 0.7, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                
                # Parameters Section
                Label:
                    text: 'Option Parameters'
                    font_size: sp(18)
                    bold: True
                    size_hint_y: None
                    height: dp(30)
                    halign: 'left'
                    text_size: self.size
                
                # Current Price
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Current Stock Price'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    TextInput:
                        text: root.current_price
                        hint_text: 'Current price'
                        multiline: False
                        input_filter: 'float'
                        font_size: sp(16)
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.current_price = self.text
                
                # Strike Price
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Strike Price'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    TextInput:
                        text: root.strike_price
                        hint_text: 'Strike price'
                        multiline: False
                        input_filter: 'float'
                        font_size: sp(16)
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.strike_price = self.text
                
                # Expiration Date
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Expiration Date (YYYY-MM-DD)'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    TextInput:
                        text: root.expiration_date
                        hint_text: '2024-12-31'
                        multiline: False
                        font_size: sp(16)
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.expiration_date = self.text
                
                # Volatility
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Volatility (%)'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    TextInput:
                        text: root.volatility
                        hint_text: 'e.g., 25.5'
                        multiline: False
                        input_filter: 'float'
                        font_size: sp(16)
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.volatility = self.text
                
                # Option Type Toggle
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(10)
                    
                    Label:
                        text: 'Option Type:'
                        font_size: sp(14)
                        size_hint_x: 0.4
                        halign: 'left'
                        text_size: self.size
                    
                    ToggleButton:
                        text: 'CALL'
                        group: 'option_type'
                        state: 'down' if root.option_type == 'call' else 'normal'
                        on_press: root.option_type = 'call'
                        background_color: (0.2, 0.8, 0.2, 1) if self.state == 'down' else (0.5, 0.5, 0.5, 1)
                    
                    ToggleButton:
                        text: 'PUT'
                        group: 'option_type'
                        state: 'down' if root.option_type == 'put' else 'normal'
                        on_press: root.option_type = 'put'
                        background_color: (0.8, 0.2, 0.2, 1) if self.state == 'down' else (0.5, 0.5, 0.5, 1)
                
                # Risk-Free Rate
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Risk-Free Rate (%)'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    BoxLayout:
                        size_hint_y: None
                        height: dp(48)
                        spacing: dp(5)
                        
                        TextInput:
                            text: root.risk_free_rate
                            hint_text: 'e.g., 4.5'
                            multiline: False
                            input_filter: 'float'
                            font_size: sp(16)
                            on_text: root.risk_free_rate = self.text
                        
                        Button:
                            text: 'Save'
                            size_hint_x: 0.25
                            on_press: root.save_risk_free_rate()
                            background_color: 0.3, 0.7, 0.3, 1
                
                # Dividend Rate
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(70)
                    spacing: dp(5)
                    
                    Label:
                        text: 'Dividend Yield (%)'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(25)
                        halign: 'left'
                        text_size: self.size
                    
                    TextInput:
                        text: root.dividend_rate
                        hint_text: 'e.g., 2.0'
                        multiline: False
                        input_filter: 'float'
                        font_size: sp(16)
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.dividend_rate = self.text
                
                # Calculate Button
                Button:
                    text: 'CALCULATE OPTION PRICE'
                    size_hint_y: None
                    height: dp(60)
                    font_size: sp(18)
                    bold: True
                    on_press: root.calculate_option()
                    background_color: 0.2, 0.6, 0.86, 1
                
                # Separator
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: 0.7, 0.7, 0.7, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                
                # Results Section
                Label:
                    text: 'Results'
                    font_size: sp(18)
                    bold: True
                    size_hint_y: None
                    height: dp(30)
                    halign: 'left'
                    text_size: self.size
                
                # Option Price
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(50)
                    padding: dp(10)
                    canvas.before:
                        Color:
                            rgba: 0.9, 0.95, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(5)]
                    
                    Label:
                        text: 'Option Price:'
                        font_size: sp(16)
                        bold: True
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.calculated_price
                        font_size: sp(20)
                        bold: True
                        color: 0.2, 0.6, 0.86, 1
                        halign: 'right'
                        text_size: self.size
                
                # Greeks
                Label:
                    text: 'Greeks'
                    font_size: sp(16)
                    bold: True
                    size_hint_y: None
                    height: dp(25)
                    halign: 'left'
                    text_size: self.size
                
                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(5)
                    padding: dp(5)
                    
                    # Delta
                    Label:
                        text: 'Delta:'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.delta_value
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'right'
                        text_size: self.size
                    
                    # Gamma
                    Label:
                        text: 'Gamma:'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.gamma_value
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'right'
                        text_size: self.size
                    
                    # Theta
                    Label:
                        text: 'Theta:'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.theta_value
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'right'
                        text_size: self.size
                    
                    # Vega
                    Label:
                        text: 'Vega:'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.vega_value
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'right'
                        text_size: self.size
                    
                    # Rho
                    Label:
                        text: 'Rho:'
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    
                    Label:
                        text: root.rho_value
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(30)
                        halign: 'right'
                        text_size: self.size
                
                # Bottom padding
                Widget:
                    size_hint_y: None
                    height: dp(20)
